root = true

# ---------------------------------------------------------------------------
# All files
# ---------------------------------------------------------------------------
[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# ---------------------------------------------------------------------------
# C++ source and headers
# ---------------------------------------------------------------------------
[*.{cpp,cc,cxx,c,h,hpp,hxx}]
indent_style = space
indent_size = 4

# ---------------------------------------------------------------------------
# CMake
# ---------------------------------------------------------------------------
[{CMakeLists.txt,*.cmake}]
indent_style = space
indent_size = 4

# ---------------------------------------------------------------------------
# JSON
# ---------------------------------------------------------------------------
[*.json]
indent_style = space
indent_size = 2

# ---------------------------------------------------------------------------
# YAML
# ---------------------------------------------------------------------------
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ---------------------------------------------------------------------------
# Markdown — trailing spaces are significant (line breaks)
# ---------------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false

# ---------------------------------------------------------------------------
# SQL
# ---------------------------------------------------------------------------
[*.sql]
indent_style = space
indent_size = 4

# ---------------------------------------------------------------------------
# Shell scripts
# ---------------------------------------------------------------------------
[*.sh]
indent_style = space
indent_size = 4

# ---------------------------------------------------------------------------
# Python (scripts / tooling)
# ---------------------------------------------------------------------------
[*.py]
indent_style = space
indent_size = 4
